<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Explore - Chess Tackler</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/particles.js"></script>
  <link rel="stylesheet" href="https://unpkg.com/lucide@latest/dist/umd/lucide.css" />

  <style>
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }
    .glow-gold { box-shadow: 0 0 10px rgba(255,215,0,.3), 0 0 20px rgba(255,215,0,.2); }
    .gold-border { border: 1px solid rgba(255,215,0,.4); }
    #particles-js { position:fixed; width:100%; height:100%; z-index:-1; top:0; left:0; }
    .nav-link:hover { color:#facc15; }
    .btn-premium { background-color:#facc15; color:#0f172a; font-weight:600; transition:background .3s; }
    .btn-premium:hover { background-color:#eab308; }
    .badge-premium { background-color:#facc15; color:#1e293b; }
    .badge-premium:hover { background-color:#fde047; }

    /* Hamburger */
    #mobile-nav { display:none; flex-direction:column; gap:0; background:#0f172a; border-top:1px solid rgba(202,138,4,.3); padding:12px 2rem; }
    #mobile-nav.open { display:flex; }
    #mobile-nav a { padding:10px 0; font-size:.9rem; font-weight:500; color:#fef9c3; text-decoration:none; border-bottom:1px solid rgba(255,255,255,.05); transition:color .2s; }
    #mobile-nav a:hover { color:#facc15; }
    .hamburger-btn { display:flex; flex-direction:column; gap:5px; background:none; border:none; cursor:pointer; padding:4px; }
    .hamburger-btn span { display:block; width:22px; height:2px; background:#fef9c3; border-radius:2px; transition:all .25s ease; }
    .hamburger-btn.open span:nth-child(1) { transform:translateY(7px) rotate(45deg); }
    .hamburger-btn.open span:nth-child(2) { opacity:0; transform:scaleX(0); }
    .hamburger-btn.open span:nth-child(3) { transform:translateY(-7px) rotate(-45deg); }

    /* Profile pill */
    .profile-wrap { position:relative; }
    .profile-pill { display:flex; align-items:center; gap:8px; padding:5px 14px 5px 6px; background:rgba(250,204,21,.1); border:1.5px solid rgba(250,204,21,.4); border-radius:99px; cursor:pointer; transition:background .2s,box-shadow .2s; font-size:.78rem; font-weight:600; color:#facc15; user-select:none; }
    .profile-pill:hover { background:rgba(250,204,21,.18); box-shadow:0 0 12px rgba(250,204,21,.25); }
    .profile-avatar { width:26px; height:26px; border-radius:50%; background:linear-gradient(135deg,#facc15,#ca8a04); display:flex; align-items:center; justify-content:center; font-size:.65rem; font-weight:700; color:#0f172a; flex-shrink:0; }
    .profile-username { max-width:100px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .profile-chevron { width:12px; height:12px; color:#facc15; transition:transform .25s; flex-shrink:0; }
    .profile-wrap.open .profile-chevron { transform:rotate(180deg); }
    .profile-dropdown { display:none; position:absolute; right:0; top:calc(100% + 8px); background:#141e35; border:1px solid rgba(250,204,21,.25); border-radius:12px; min-width:220px; overflow:hidden; box-shadow:0 12px 40px rgba(0,0,0,.6); z-index:200; animation:dropIn .18s ease; }
    .profile-wrap.open .profile-dropdown { display:block; }
    @keyframes dropIn { from{opacity:0;transform:translateY(-6px)} to{opacity:1;transform:translateY(0)} }
    .pd-head { padding:14px 16px; background:rgba(250,204,21,.07); border-bottom:1px solid rgba(250,204,21,.12); }
    .pd-name  { font-weight:700; font-size:.88rem; color:#facc15; }
    .pd-email { font-size:.7rem; color:#94a3b8; margin-top:2px; }
    .pd-since { font-size:.65rem; color:rgba(250,204,21,.35); margin-top:4px; }
    .dd-item { display:flex; align-items:center; gap:9px; padding:10px 16px; font-size:.8rem; font-weight:500; color:#e2d9c5; text-decoration:none; cursor:pointer; transition:background .15s; border:none; background:none; width:100%; text-align:left; }
    .dd-item svg { color:#94a3b8; flex-shrink:0; }
    .dd-item:hover { background:rgba(250,204,21,.07); color:#facc15; }
    .dd-item:hover svg { color:#facc15; }
    .dd-item.danger { color:#f87171; }
    .dd-item.danger svg { color:#fca5a5; }
    .dd-item.danger:hover { background:rgba(248,113,113,.08); }
    .dd-divider { height:1px; background:rgba(250,204,21,.1); margin:4px 0; }
    .auth-out-login { background:transparent; border:1.5px solid rgba(250,204,21,.4); color:#facc15; font-size:.78rem; font-weight:600; padding:6px 16px; border-radius:8px; text-decoration:none; transition:background .2s; }
    .auth-out-login:hover { background:rgba(250,204,21,.1); }

    /* Dashboard */
    #dashboard-section { max-width:1100px; margin:0 auto; padding:3rem 2rem 5rem; }
    .dash-section-title { font-size:1.4rem; font-weight:700; color:#facc15; margin-bottom:4px; display:flex; align-items:center; gap:10px; }
    .dash-section-sub { font-size:.82rem; color:#94a3b8; margin-bottom:2rem; }
    .dash-guest { text-align:center; padding:3rem 1.5rem; border:1px dashed rgba(250,204,21,.2); border-radius:16px; background:rgba(250,204,21,.03); }
    .dash-guest .g-icon { font-size:2.8rem; margin-bottom:1rem; }
    .dash-guest h3 { font-size:1rem; font-weight:700; color:#facc15; margin-bottom:8px; }
    .dash-guest p  { font-size:.82rem; color:#94a3b8; margin-bottom:1.5rem; }
    .dash-guest-btns { display:flex; gap:12px; justify-content:center; flex-wrap:wrap; }
    .dg-btn { padding:8px 22px; border-radius:8px; font-weight:600; font-size:.8rem; text-decoration:none; transition:all .2s; }
    .dg-primary { background:#facc15; color:#0f172a; }
    .dg-primary:hover { background:#eab308; }
    .dg-secondary { border:1.5px solid rgba(250,204,21,.35); color:#facc15; }
    .dg-secondary:hover { background:rgba(250,204,21,.08); }
    .dash-profile-card { display:flex; align-items:center; gap:16px; background:rgba(250,204,21,.06); border:1px solid rgba(250,204,21,.2); border-radius:14px; padding:18px 22px; margin-bottom:20px; }
    .dp-avatar { width:54px; height:54px; border-radius:50%; background:linear-gradient(135deg,#facc15,#ca8a04); display:flex; align-items:center; justify-content:center; font-size:1.3rem; font-weight:700; color:#0f172a; flex-shrink:0; box-shadow:0 0 16px rgba(250,204,21,.35); }
    .dp-info { flex:1; min-width:0; }
    .dp-name   { font-weight:700; font-size:1rem; color:#facc15; }
    .dp-email  { font-size:.75rem; color:#94a3b8; margin-top:2px; }
    .dp-joined { font-size:.68rem; color:rgba(250,204,21,.35); margin-top:4px; }
    .dp-rank   { display:inline-block; margin-top:6px; background:#facc15; color:#0f172a; font-size:.62rem; font-weight:700; letter-spacing:.08em; padding:2px 10px; border-radius:99px; text-transform:uppercase; }
    .dash-cards { display:grid; grid-template-columns:repeat(auto-fill,minmax(160px,1fr)); gap:14px; margin-bottom:20px; }
    .dash-card { background:#141e35; border:1px solid rgba(250,204,21,.15); border-radius:12px; padding:18px 16px; transition:transform .2s,box-shadow .2s; }
    .dash-card:hover { transform:translateY(-4px); box-shadow:0 8px 24px rgba(0,0,0,.3); }
    .dc-icon  { font-size:1.4rem; margin-bottom:8px; }
    .dc-label { font-size:.62rem; letter-spacing:.1em; text-transform:uppercase; color:#94a3b8; margin-bottom:4px; }
    .dc-value { font-size:1.5rem; font-weight:700; color:#facc15; line-height:1; }
    .dc-sub   { font-size:.68rem; color:#64748b; margin-top:4px; }
    .dash-panels { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
    @media(max-width:720px){.dash-panels{grid-template-columns:1fr;}}
    .dash-panel { background:#141e35; border:1px solid rgba(250,204,21,.15); border-radius:14px; padding:20px; overflow:hidden; }
    .panel-title { font-size:.82rem; font-weight:700; color:#facc15; letter-spacing:.06em; text-transform:uppercase; margin-bottom:14px; }
    .act-list { display:flex; flex-direction:column; gap:8px; }
    .act-item { display:flex; align-items:center; gap:10px; background:rgba(250,204,21,.04); border:1px solid rgba(250,204,21,.08); border-radius:8px; padding:9px 12px; font-size:.75rem; }
    .act-dot { width:7px; height:7px; border-radius:50%; flex-shrink:0; background:#facc15; }
    .act-text { flex:1; color:#e2d9c5; }
    .act-time { font-size:.65rem; color:#64748b; white-space:nowrap; }
    .bar-list { display:flex; flex-direction:column; gap:12px; }
    .bar-row  { display:flex; flex-direction:column; gap:4px; }
    .bar-top  { display:flex; justify-content:space-between; }
    .bar-name { font-size:.75rem; color:#e2d9c5; }
    .bar-val  { font-size:.75rem; font-weight:600; color:#facc15; }
    .bar-track { height:7px; background:rgba(255,255,255,.06); border-radius:99px; overflow:hidden; }
    @keyframes barGrow { from{width:0;} }
    .bar-fill { height:100%; border-radius:99px; background:linear-gradient(90deg,#ca8a04,#facc15); animation:barGrow .9s ease both; }
    .heatmap-grid { display:grid; grid-template-columns:repeat(7,1fr); gap:4px; }
    .hm-cell { aspect-ratio:1; border-radius:3px; background:rgba(250,204,21,.07); cursor:default; }
    .hm-cell[data-level="1"]{background:rgba(250,204,21,.18);}
    .hm-cell[data-level="2"]{background:rgba(250,204,21,.38);}
    .hm-cell[data-level="3"]{background:rgba(250,204,21,.62);}
    .hm-cell[data-level="4"]{background:rgba(250,204,21,.88);}
    .hm-legend { display:flex; align-items:center; gap:5px; margin-top:10px; font-size:.65rem; color:#64748b; }
    .hm-leg { width:10px; height:10px; border-radius:2px; }
    .dash-panel.full { grid-column:1/-1; }
    .dash-reset { background:transparent; border:1px solid rgba(248,113,113,.3); color:#f87171; font-size:.7rem; padding:5px 12px; border-radius:7px; cursor:pointer; transition:all .2s; }
    .dash-reset:hover { background:rgba(248,113,113,.1); border-color:#f87171; }
    .section-divider { border:none; border-top:1px solid rgba(250,204,21,.15); margin:0 2rem 3rem; }
  </style>
</head>
