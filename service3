  <!-- NEW scripts -->
  <script>
    /* Hamburger */
    const hBtn = document.getElementById('hamburgerBtn');
    const mNav = document.getElementById('mobile-nav');
    hBtn.addEventListener('click', () => { hBtn.classList.toggle('open'); mNav.classList.toggle('open'); });
    mNav.querySelectorAll('a').forEach(a => a.addEventListener('click', () => { hBtn.classList.remove('open'); mNav.classList.remove('open'); }));

    /* Helpers */
    function initials(n) { return (n||'U').substring(0,2).toUpperCase(); }

    /* Header auth */
    function renderHeader() {
      const user  = JSON.parse(localStorage.getItem('ct_current_user') || 'null');
      const area  = document.getElementById('headerAuthArea');
      const mArea = document.getElementById('mobileAuthArea');
      if (!area) return;
      if (user) {
        area.innerHTML = `
          <div class="profile-wrap" id="profileWrap">
            <div class="profile-pill" onclick="togglePM(event)">
              <div class="profile-avatar">${initials(user.username)}</div>
              <span class="profile-username">${user.username}</span>
              <svg class="profile-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
            </div>
            <div class="profile-dropdown">
              <div class="pd-head">
                <div class="pd-name">&#9822; ${user.username}</div>
                <div class="pd-email">${user.email}</div>
                <div class="pd-since">Member since ${user.joinedAt||'recently'}</div>
              </div>
              <a href="index.html" class="dd-item">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
                Home
              </a>
              <a href="#dashboard-section" class="dd-item" onclick="closePM()">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5"/></svg>
                My Dashboard
              </a>
              <div class="dd-divider"></div>
              <button class="dd-item danger" onclick="logOut()">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75"/></svg>
                Log Out
              </button>
            </div>
          </div>`;
        if (mArea) mArea.innerHTML = `
          <div style="padding:8px 0;border-top:1px solid rgba(250,204,21,.1);margin-top:4px;">
            <div style="font-size:.8rem;font-weight:700;color:#facc15;">&#9822; ${user.username}</div>
            <div style="font-size:.68rem;color:#94a3b8;">${user.email}</div>
            <button onclick="logOut()" style="margin-top:8px;background:transparent;border:1px solid rgba(248,113,113,.35);color:#f87171;font-size:.75rem;padding:5px 14px;border-radius:7px;cursor:pointer;">Log Out</button>
          </div>`;
      } else {
        area.innerHTML = `
          <a href="authenticated.html" class="auth-out-login">Log In</a>
          <a href="authentication.html" class="btn-premium px-4 py-2 rounded-full shadow" style="font-size:.78rem;">Sign Up</a>`;
        if (mArea) mArea.innerHTML = `
          <div style="display:flex;gap:8px;padding:8px 0;border-top:1px solid rgba(250,204,21,.1);margin-top:4px;">
            <a href="authenticated.html" class="auth-out-login">Log In</a>
            <a href="authentication.html" class="btn-premium px-3 py-1 rounded-full" style="font-size:.78rem;">Sign Up</a>
          </div>`;
      }
    }
    function togglePM(e) { e.stopPropagation(); document.getElementById('profileWrap')?.classList.toggle('open'); }
    function closePM()   { document.getElementById('profileWrap')?.classList.remove('open'); }
    document.addEventListener('click', closePM);
    function logOut() { localStorage.removeItem('ct_current_user'); renderHeader(); renderDashboard(); }

    /* Dashboard */
    function trackVisit() {
      const user = JSON.parse(localStorage.getItem('ct_current_user')||'null');
      if (!user) return;
      const key = 'ct_activity_'+user.id;
      const data = JSON.parse(localStorage.getItem(key)||'{}');
      data.visits     = (data.visits||0)+1;
      data.lastVisit  = new Date().toLocaleString();
      data.firstVisit = data.firstVisit||new Date().toLocaleString();
      data.pages = data.pages||{}; data.pages['Explore'] = (data.pages['Explore']||0)+1;
      data.feed = data.feed||[]; data.feed.unshift({action:'Visited Explore page',time:new Date().toLocaleString()});
      data.feed = data.feed.slice(0,20);
      const day = new Date().toISOString().split('T')[0];
      data.heatmap = data.heatmap||{}; data.heatmap[day] = (data.heatmap[day]||0)+1;
      data.sessionStart = Date.now();
      localStorage.setItem(key, JSON.stringify(data));
    }
    window.addEventListener('beforeunload', () => {
      const user = JSON.parse(localStorage.getItem('ct_current_user')||'null'); if (!user) return;
      const key = 'ct_activity_'+user.id; const data = JSON.parse(localStorage.getItem(key)||'{}');
      if (data.sessionStart) { data.totalTime=(data.totalTime||0)+Math.round((Date.now()-data.sessionStart)/1000); delete data.sessionStart; localStorage.setItem(key,JSON.stringify(data)); }
    });
    function fmtTime(s) { if(!s||s<60) return (s||0)+'s'; if(s<3600) return Math.round(s/60)+'m'; return (s/3600).toFixed(1)+'h'; }
    function buildHeatmap(hmap) {
      let html=''; const today=new Date();
      for(let i=27;i>=0;i--){const d=new Date(today);d.setDate(d.getDate()-i);const k=d.toISOString().split('T')[0];const c=hmap[k]||0;const lv=c===0?0:c===1?1:c<=3?2:c<=6?3:4;html+=`<div class="hm-cell" data-level="${lv}" title="${k}: ${c} visit(s)"></div>`;}
      return html;
    }
    function renderDashboard() {
      const user=JSON.parse(localStorage.getItem('ct_current_user')||'null');
      const content=document.getElementById('dashContent'); const sub=document.getElementById('dashSub'); const rBtn=document.getElementById('resetBtn');
      if(!content) return;
      if(!user) {
        if(rBtn) rBtn.style.display='none';
        if(sub) sub.textContent='Track your journey across Chess Tackler';
        content.innerHTML=`<div class="dash-guest"><div class="g-icon">&#9822;</div><h3>Sign in to see your Dashboard</h3><p>Create a free account to track visits, time spent, favourite pages and activity history.</p><div class="dash-guest-btns"><a href="authentication.html" class="dg-btn dg-primary">Create Account</a><a href="authenticated.html" class="dg-btn dg-secondary">Log In</a></div></div>`;
        return;
      }
      if(rBtn) rBtn.style.display='inline-block';
      if(sub) sub.innerHTML=`Welcome back, <span style="color:#facc15;font-weight:600;">${user.username}</span> — here's your activity.`;
      const key='ct_activity_'+user.id; const data=JSON.parse(localStorage.getItem(key)||'{}');
      const visits=data.visits||0; const totalTime=data.totalTime||0; const feed=data.feed||[]; const pages=data.pages||{}; const heatmap=data.heatmap||{};
      const rank=visits>=50?'Grand Master':visits>=20?'Expert':visits>=10?'Intermediate':visits>=3?'Beginner':'Newcomer';
      const allPages={Explore:0,Home:0,Puzzles:0,Rankings:0,'Fun Zone':0,Lessons:0,...pages};
      const maxPV=Math.max(...Object.values(allPages),1);
      const barsHTML=Object.entries(allPages).map(([name,count])=>`<div class="bar-row"><div class="bar-top"><span class="bar-name">${name}</span><span class="bar-val">${count}</span></div><div class="bar-track"><div class="bar-fill" style="width:${(count/maxPV*100).toFixed(1)}%"></div></div></div>`).join('');
      const feedHTML=feed.length?feed.slice(0,8).map(f=>`<div class="act-item"><div class="act-dot"></div><span class="act-text">${f.action}</span><span class="act-time">${f.time}</span></div>`).join(''):`<div style="text-align:center;color:#64748b;font-size:.78rem;padding:1rem;">No activity yet. Start exploring!</div>`;
      content.innerHTML=`
        <div class="dash-profile-card">
          <div class="dp-avatar">${initials(user.username)}</div>
          <div class="dp-info">
            <div class="dp-name">&#9822; ${user.username}</div>
            <div class="dp-email">${user.email}</div>
            <div class="dp-joined">Member since: ${user.joinedAt||'—'} &nbsp;&middot;&nbsp; Contact: ${user.contact||'—'}</div>
            <div class="dp-rank">${rank}</div>
          </div>
        </div>
        <div class="dash-cards">
          <div class="dash-card"><div class="dc-icon">&#128065;</div><div class="dc-label">Total Visits</div><div class="dc-value">${visits}</div><div class="dc-sub">All pages</div></div>
          <div class="dash-card"><div class="dc-icon">&#9201;</div><div class="dc-label">Time Spent</div><div class="dc-value">${fmtTime(totalTime)}</div><div class="dc-sub">Total on site</div></div>
          <div class="dash-card"><div class="dc-icon">&#128197;</div><div class="dc-label">First Visit</div><div class="dc-value" style="font-size:1rem;">${data.firstVisit?data.firstVisit.split(',')[0]:'—'}</div><div class="dc-sub">When you found us</div></div>
          <div class="dash-card"><div class="dc-icon">&#128336;</div><div class="dc-label">Last Seen</div><div class="dc-value" style="font-size:1rem;">${data.lastVisit?data.lastVisit.split(',')[0]:'—'}</div><div class="dc-sub">Most recent</div></div>
          <div class="dash-card"><div class="dc-icon">&#127885;</div><div class="dc-label">Player Rank</div><div class="dc-value" style="font-size:1rem;">${rank}</div><div class="dc-sub">By activity</div></div>
          <div class="dash-card"><div class="dc-icon">&#128196;</div><div class="dc-label">Pages Explored</div><div class="dc-value">${Object.keys(pages).length}</div><div class="dc-sub">Unique sections</div></div>
        </div>
        <div class="dash-panels">
          <div class="dash-panel"><div class="panel-title">&#9889; Recent Activity</div><div class="act-list">${feedHTML}</div></div>
          <div class="dash-panel"><div class="panel-title">&#128202; Page Visit Breakdown</div><div class="bar-list">${barsHTML}</div></div>
          <div class="dash-panel full"><div class="panel-title">&#128197; Visit Heatmap — Last 28 Days</div><div class="heatmap-grid">${buildHeatmap(heatmap)}</div><div class="hm-legend">Less &nbsp;<div class="hm-leg" style="background:rgba(250,204,21,.07)"></div><div class="hm-leg" style="background:rgba(250,204,21,.18)"></div><div class="hm-leg" style="background:rgba(250,204,21,.38)"></div><div class="hm-leg" style="background:rgba(250,204,21,.62)"></div><div class="hm-leg" style="background:rgba(250,204,21,.88)"></div>&nbsp; More</div></div>
        </div>`;
    }
    function resetDashboard() {
      const user=JSON.parse(localStorage.getItem('ct_current_user')||'null');
      if(!user||!confirm('Reset all your activity data? This cannot be undone.')) return;
      localStorage.removeItem('ct_activity_'+user.id); trackVisit(); renderDashboard();
    }
    window.addEventListener('DOMContentLoaded', () => { renderHeader(); trackVisit(); renderDashboard(); });
  </script>
</body>
</html>